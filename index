<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Our AI Mastery Roadmap</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap');

:root {
  --mindset:  #6366F1;
  --ai101:    #3B82F6;
  --prompt:   #F59E0B;
  --llm:      #06B6D4;
  --agents:   #EC4899;
  --courses:  #10B981;
  --path:     #F97316;
  --bg:       #0C0C12;
  --surface:  #13131C;
  --s2:       #1C1C28;
  --s3:       #242434;
  --border:   #2A2A3E;
  --text:     #E2E2EE;
  --muted:    #7070A0;
  --sw: 260px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  font-family: 'Inter', sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.7;
  display: flex;
  min-height: 100vh;
}

/* ── SIDEBAR ─────────────────────────── */
.sidebar {
  position: fixed; left: 0; top: 0; bottom: 0;
  width: var(--sw);
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  z-index: 100; overflow: hidden;
}

.sidebar-top {
  padding: 22px 18px 16px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.sidebar-logo {
  font-size: 13px; font-weight: 800;
  letter-spacing: .06em; text-transform: uppercase;
  color: #fff; display: flex; align-items: center; gap: 8px;
}
.sidebar-logo span { color: var(--muted); font-weight: 400; }
.sidebar-sub { font-size: 11px; color: var(--muted); margin-top: 3px; }

.sidebar-progress {
  padding: 12px 18px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.progress-label { font-size: 11px; color: var(--muted); margin-bottom: 6px; display: flex; justify-content: space-between; }
.progress-bar { height: 3px; background: var(--border); border-radius: 99px; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg,#6366F1,#EC4899); border-radius: 99px; transition: width .4s ease; }

.nav-scroll { flex: 1; overflow-y: auto; padding: 10px 10px 20px; }
.nav-label { font-size: 10px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--muted); padding: 12px 8px 5px; display: block; }

.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 10px; border-radius: 8px; cursor: pointer;
  font-size: 13px; font-weight: 500; color: var(--text);
  transition: background .12s, color .12s; margin-bottom: 1px;
  border: none; background: none; width: 100%; text-align: left;
}
.nav-item:hover { background: var(--s2); }
.nav-item.active { background: var(--s3); color: #fff; }
.nav-item.active .nav-num { color: #fff; }

.nav-num {
  width: 22px; height: 22px; border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 700; color: var(--muted);
  flex-shrink: 0; border: 1px solid var(--border);
}
.nav-item.active .nav-num { border-color: transparent; }

.nav-dot {
  width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
}

/* ── MAIN ────────────────────────────── */
.main { margin-left: var(--sw); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }

/* pages hidden by default */
.page { display: none; flex: 1; flex-direction: column; }
.page.active { display: flex; }

/* ── HOME PAGE ───────────────────────── */
.home-hero {
  padding: 80px 72px 64px;
  background: linear-gradient(160deg, #0C0C18 0%, #14102A 45%, #0C1420 100%);
  border-bottom: 1px solid var(--border);
  position: relative; overflow: hidden;
}
.home-hero::before {
  content: ''; position: absolute; top: -80px; right: -80px;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(99,102,241,.12) 0%, transparent 65%);
  pointer-events: none;
}
.home-hero::after {
  content: ''; position: absolute; bottom: -60px; left: 25%;
  width: 360px; height: 360px;
  background: radial-gradient(circle, rgba(236,72,153,.08) 0%, transparent 65%);
  pointer-events: none;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(99,102,241,.12); border: 1px solid rgba(99,102,241,.3);
  border-radius: 100px; padding: 5px 14px; font-size: 12px; font-weight: 600;
  color: #A5B4FC; letter-spacing: .04em; margin-bottom: 28px;
}
.home-hero h1 {
  font-size: clamp(36px, 5vw, 58px); font-weight: 800;
  line-height: 1.1; letter-spacing: -.03em; color: #fff;
  max-width: 700px; margin-bottom: 22px;
}
.home-hero h1 em {
  font-style: normal;
  background: linear-gradient(135deg,#818CF8,#C084FC,#F472B6);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.home-hero p {
  font-size: 17px; color: rgba(255,255,255,.6); max-width: 580px;
  line-height: 1.75; margin-bottom: 40px;
}
.hero-cta {
  display: inline-flex; align-items: center; gap: 10px;
  background: linear-gradient(135deg,#6366F1,#8B5CF6);
  color: #fff; padding: 14px 28px; border-radius: 12px;
  font-size: 15px; font-weight: 700; cursor: pointer;
  border: none; transition: opacity .15s, transform .15s; text-decoration: none;
}
.hero-cta:hover { opacity: .9; transform: translateY(-1px); }

.home-how {
  padding: 52px 72px;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
}
.section-eyebrow {
  font-size: 11px; font-weight: 700; letter-spacing: .12em;
  text-transform: uppercase; color: var(--muted); margin-bottom: 14px;
}
.home-how h2 { font-size: 22px; font-weight: 700; color: #fff; margin-bottom: 24px; }
.how-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap: 14px; }
.how-card {
  background: var(--s2); border: 1px solid var(--border); border-radius: 12px;
  padding: 18px 20px; display: flex; gap: 14px; align-items: flex-start;
}
.how-icon { font-size: 22px; flex-shrink: 0; margin-top: 1px; }
.how-card strong { display: block; font-size: 13px; font-weight: 700; color: #fff; margin-bottom: 4px; }
.how-card p { font-size: 13px; color: var(--muted); line-height: 1.5; }

.home-sections { padding: 52px 72px; }
.home-sections h2 { font-size: 22px; font-weight: 700; color: #fff; margin-bottom: 28px; }
.course-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px,1fr)); gap: 16px; }

.course-card {
  background: var(--surface); border: 1px solid var(--border); border-radius: 16px;
  padding: 24px; cursor: pointer; transition: transform .15s, border-color .15s;
  text-align: left; border-left: 3px solid;
}
.course-card:hover { transform: translateY(-3px); border-color: rgba(255,255,255,.12); }
.course-card-icon { font-size: 28px; margin-bottom: 12px; display: block; }
.course-card h3 { font-size: 15px; font-weight: 700; color: #fff; margin-bottom: 6px; }
.course-card p { font-size: 13px; color: var(--muted); line-height: 1.5; }
.course-card-num { font-size: 11px; font-weight: 600; letter-spacing: .06em; margin-top: 14px; opacity: .5; }

/* ── CONTENT PAGES ───────────────────── */
.page-header {
  padding: 48px 72px 40px;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
  position: relative; overflow: hidden;
}
.page-header::after {
  content: ''; position: absolute; top: -60px; right: -40px;
  width: 280px; height: 280px;
  background: radial-gradient(circle, var(--accent-glow, rgba(99,102,241,.12)) 0%, transparent 65%);
  pointer-events: none;
}
.page-eyebrow {
  display: flex; align-items: center; gap: 10px;
  font-size: 12px; font-weight: 600; letter-spacing: .08em;
  text-transform: uppercase; color: var(--muted); margin-bottom: 16px;
}
.page-eyebrow .dot { width: 6px; height: 6px; border-radius: 50%; }
.page-header h1 {
  font-size: clamp(26px, 4vw, 40px); font-weight: 800;
  letter-spacing: -.02em; color: #fff; line-height: 1.15; margin-bottom: 12px;
}
.page-header .lead {
  font-size: 16px; color: rgba(255,255,255,.6); max-width: 620px; line-height: 1.7;
}

.page-body { padding: 52px 72px; flex: 1; }

/* ── CALLOUT ─────────────────────────── */
.callout {
  background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.09);
  border-radius: 12px; padding: 18px 22px;
  font-size: 15px; color: rgba(255,255,255,.8); line-height: 1.7; margin: 28px 0;
}
.callout.colored { border-left: 3px solid; border-radius: 0 12px 12px 0; }

/* ── TOPIC SECTION ───────────────────── */
.topic-section { margin: 40px 0; }
.topic-section + .topic-section { border-top: 1px solid var(--border); padding-top: 40px; }

.topic-heading {
  display: flex; align-items: center; gap: 12px;
  margin-bottom: 16px;
}
.topic-tag {
  display: inline-flex; align-items: center; justify-content: center;
  width: 34px; height: 34px; border-radius: 10px; font-size: 16px; flex-shrink: 0;
}
.topic-heading h2 { font-size: 19px; font-weight: 700; color: #fff; }
.topic-heading p.sub { font-size: 12px; color: var(--muted); margin-top: 2px; }

.topic-body { font-size: 15px; color: rgba(255,255,255,.72); line-height: 1.8; }
.topic-body p { margin-bottom: 14px; }
.topic-body p:last-child { margin-bottom: 0; }
.topic-body strong { color: #fff; font-weight: 600; }
.topic-body em { color: rgba(255,255,255,.5); font-style: italic; }

/* ── LISTS ───────────────────────────── */
.content-list { list-style: none; margin: 16px 0; }
.content-list li {
  font-size: 15px; color: rgba(255,255,255,.72); line-height: 1.65;
  padding: 10px 0 10px 20px; border-bottom: 1px solid rgba(255,255,255,.05);
  position: relative;
}
.content-list li:last-child { border-bottom: none; }
.content-list li::before { content: '›'; position: absolute; left: 3px; color: var(--muted); }
.content-list li strong { color: #fff; font-weight: 600; }

/* ── INFO CARDS GRID ─────────────────── */
.cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px,1fr)); gap: 14px; margin: 24px 0; }
.info-card {
  background: var(--s2); border: 1px solid var(--border); border-radius: 12px; padding: 20px;
}
.info-card-icon { font-size: 22px; margin-bottom: 10px; }
.info-card h3 { font-size: 14px; font-weight: 700; color: #fff; margin-bottom: 6px; }
.info-card p { font-size: 13px; color: var(--muted); line-height: 1.55; }

/* ── LEVEL BLOCKS ────────────────────── */
.level-block {
  background: var(--s2); border: 1px solid var(--border); border-radius: 14px;
  overflow: hidden; margin: 24px 0;
}
.level-header {
  padding: 14px 20px; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 12px;
}
.level-badge {
  font-size: 10px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
  padding: 3px 10px; border-radius: 100px;
}
.level-header h3 { font-size: 14px; font-weight: 700; color: #fff; }
.level-header p { font-size: 12px; color: var(--muted); margin-top: 1px; }
.level-body { padding: 20px; }

/* ── TIMELINE ────────────────────────── */
.timeline { margin: 24px 0; }
.timeline-item {
  display: flex; gap: 20px; padding: 14px 0;
  border-bottom: 1px solid rgba(255,255,255,.05);
}
.timeline-item:last-child { border-bottom: none; }
.timeline-year {
  font-size: 12px; font-weight: 700; color: var(--muted);
  min-width: 48px; padding-top: 2px;
}
.timeline-content h4 { font-size: 14px; font-weight: 700; color: #fff; margin-bottom: 4px; }
.timeline-content p { font-size: 13.5px; color: rgba(255,255,255,.6); line-height: 1.55; }

/* ── TERM GLOSSARY ───────────────────── */
.glossary { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px,1fr)); gap: 12px; margin: 24px 0; }
.term-card {
  background: var(--s2); border: 1px solid var(--border); border-radius: 10px;
  padding: 16px 18px;
}
.term-card .term { font-size: 13px; font-weight: 700; color: #fff; margin-bottom: 6px; }
.term-card .def { font-size: 13px; color: rgba(255,255,255,.6); line-height: 1.55; }

/* ── CHALLENGE BLOCK ─────────────────── */
.challenges-wrap {
  background: rgba(236,72,153,.06); border: 1px solid rgba(236,72,153,.2);
  border-radius: 16px; padding: 28px; margin: 36px 0;
}
.challenges-wrap h2 {
  font-size: 17px; font-weight: 800; color: #F472B6;
  display: flex; align-items: center; gap: 8px; margin-bottom: 6px;
}
.challenges-wrap .cw-sub { font-size: 13px; color: rgba(244,114,182,.6); margin-bottom: 20px; }

.challenge {
  background: rgba(0,0,0,.25); border-radius: 10px; padding: 18px 20px;
  margin-bottom: 12px; border-left: 3px solid rgba(236,72,153,.45);
}
.challenge:last-child { margin-bottom: 0; }
.challenge h4 { font-size: 13.5px; font-weight: 700; color: #fff; margin-bottom: 7px; }
.challenge p { font-size: 13.5px; color: rgba(255,255,255,.65); line-height: 1.65; }
.challenge ul { list-style: disc; padding-left: 18px; margin-top: 8px; }
.challenge ul li { font-size: 13.5px; color: rgba(255,255,255,.6); line-height: 1.6; padding: 2px 0; }

/* ── COMPARISON TABLE ────────────────── */
.compare-table { width: 100%; border-collapse: collapse; margin: 24px 0; font-size: 14px; }
.compare-table th {
  text-align: left; padding: 12px 16px; font-size: 11px; font-weight: 700;
  letter-spacing: .08em; text-transform: uppercase; color: var(--muted);
  border-bottom: 1px solid var(--border); background: var(--s2);
}
.compare-table td {
  padding: 13px 16px; border-bottom: 1px solid rgba(255,255,255,.04);
  color: rgba(255,255,255,.72); vertical-align: top; line-height: 1.55;
}
.compare-table td:first-child { font-weight: 600; color: #fff; }
.compare-table tr:last-child td { border-bottom: none; }

/* ── PHASE BLOCK (Learning Path) ─────── */
.phase {
  background: var(--surface); border: 1px solid var(--border); border-radius: 14px;
  overflow: hidden; margin: 20px 0;
}
.phase-head {
  padding: 16px 22px; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
}
.phase-head h3 { font-size: 15px; font-weight: 700; color: #fff; display: flex; align-items: center; gap: 8px; }
.phase-head .sub { font-size: 12px; color: var(--muted); }
.tasks { padding: 6px 0; }
.task {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 11px 22px; cursor: pointer; transition: background .1s;
}
.task:hover { background: rgba(255,255,255,.025); }
.check {
  width: 18px; height: 18px; border: 2px solid rgba(255,255,255,.2);
  border-radius: 5px; flex-shrink: 0; margin-top: 2px;
  display: flex; align-items: center; justify-content: center;
  transition: all .15s; font-size: 11px; font-weight: 700; color: #fff;
}
.task.done .check { background: #10B981; border-color: #10B981; }
.task p { font-size: 14px; color: rgba(255,255,255,.75); line-height: 1.5; }
.task.done p { color: rgba(255,255,255,.3); text-decoration: line-through; }

/* ── COURSE RESOURCE CARD ────────────── */
.resource-group { margin: 28px 0; }
.resource-group h3 {
  font-size: 15px; font-weight: 700; color: #fff;
  display: flex; align-items: center; gap: 8px; margin-bottom: 12px;
}
.resource-items { background: var(--s2); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
.resource-item {
  padding: 15px 20px; border-bottom: 1px solid var(--border);
  display: flex; gap: 14px; align-items: flex-start;
}
.resource-item:last-child { border-bottom: none; }
.resource-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 6px; }
.resource-item .name { font-size: 14px; font-weight: 600; color: #fff; margin-bottom: 3px; }
.resource-item .desc { font-size: 13px; color: var(--muted); line-height: 1.5; }
.resource-empty {
  padding: 22px 20px; text-align: center; font-size: 13px;
  color: rgba(255,255,255,.2); font-style: italic; border: 2px dashed rgba(255,255,255,.07); border-radius: 10px;
}

/* ── PAGE NAV ────────────────────────── */
.page-nav {
  padding: 32px 72px;
  border-top: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  background: var(--surface); margin-top: auto;
}
.nav-btn {
  display: flex; align-items: center; gap: 10px;
  background: var(--s2); border: 1px solid var(--border); color: var(--text);
  padding: 12px 20px; border-radius: 10px; cursor: pointer;
  font-size: 14px; font-weight: 600; transition: background .12s, border-color .12s;
}
.nav-btn:hover { background: var(--s3); border-color: rgba(255,255,255,.12); }
.nav-btn:disabled { opacity: .3; cursor: default; pointer-events: none; }
.nav-btn .direction { font-size: 11px; font-weight: 400; color: var(--muted); display: block; }

.page-indicator { font-size: 13px; color: var(--muted); font-weight: 500; }

/* ── SCROLLBAR ───────────────────────── */
::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }

/* ── MOBILE HEADER ───────────────────── */
.mobile-header {
  display: none;
  position: fixed; top: 0; left: 0; right: 0; height: 52px;
  background: var(--surface); border-bottom: 1px solid var(--border);
  align-items: center; justify-content: space-between;
  padding: 0 18px; z-index: 200;
}
.mobile-menu-btn {
  background: none; border: 1px solid var(--border); color: var(--text);
  border-radius: 8px; padding: 7px 11px; cursor: pointer; font-size: 15px; line-height: 1;
}
.mobile-logo { font-size: 13px; font-weight: 700; color: #fff; }
.mobile-logo span { color: var(--muted); font-weight: 400; }

.mobile-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,.55); z-index: 300;
}
.mobile-overlay.open { display: block; }

/* ── RESPONSIVE ──────────────────────── */
@media (max-width: 900px) {
  .sidebar {
    transform: translateX(-100%);
    transition: transform .25s ease;
    z-index: 400;
  }
  .sidebar.open { transform: translateX(0); }
  .main { margin-left: 0; padding-top: 52px; }
  .mobile-header { display: flex; }
  .home-hero, .home-how, .home-sections, .page-header, .page-body, .page-nav { padding-left: 24px; padding-right: 24px; }
}

/* ── DIVIDER ─────────────────────────── */
.divider { border: none; border-top: 1px solid var(--border); margin: 36px 0; }

/* back-to-top */
#btt { position: fixed; bottom: 28px; right: 28px; background: var(--s2); border: 1px solid var(--border); color: var(--text); border-radius: 50%; width: 40px; height: 40px; display: none; align-items: center; justify-content: center; cursor: pointer; font-size: 16px; z-index: 200; transition: background .12s; }
#btt:hover { background: var(--s3); }
#btt.show { display: flex; }
</style>
</head>
<body>

<!-- MOBILE HEADER -->
<header class="mobile-header">
  <button class="mobile-menu-btn" onclick="openMobileMenu()" aria-label="Open menu">☰</button>
  <div class="mobile-logo">🗺️ AI Mastery <span>Roadmap</span></div>
  <div style="width:38px"></div>
</header>
<div class="mobile-overlay" id="mobile-overlay" onclick="closeMobileMenu()"></div>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sidebar-top">
    <div class="sidebar-logo">🗺️ AI Mastery <span>Roadmap</span></div>
    <div class="sidebar-sub">Jeremiah &amp; DeNon · March 2026</div>
  </div>
  <div class="sidebar-progress">
    <div class="progress-label"><span>Progress</span><span id="prog-text">0 of 7</span></div>
    <div class="progress-bar"><div class="progress-fill" id="prog-fill" style="width:0%"></div></div>
  </div>
  <nav class="nav-scroll">
    <span class="nav-label">Start</span>
    <button class="nav-item active" onclick="goTo(0)" id="nav-0">
      <div class="nav-num">🏠</div>
      Home
    </button>
    <span class="nav-label">The Curriculum</span>
    <button class="nav-item" onclick="goTo(1)" id="nav-1">
      <div class="nav-num" style="background:rgba(99,102,241,.2);border-color:rgba(99,102,241,.3);color:#818CF8">1</div>
      🎯 The Right Mindset
    </button>
    <button class="nav-item" onclick="goTo(2)" id="nav-2">
      <div class="nav-num" style="background:rgba(59,130,246,.2);border-color:rgba(59,130,246,.3);color:#60A5FA">2</div>
      📖 AI 101
    </button>
    <button class="nav-item" onclick="goTo(3)" id="nav-3">
      <div class="nav-num" style="background:rgba(245,158,11,.2);border-color:rgba(245,158,11,.3);color:#FCD34D">3</div>
      💬 Prompting
    </button>
    <button class="nav-item" onclick="goTo(4)" id="nav-4">
      <div class="nav-num" style="background:rgba(6,182,212,.2);border-color:rgba(6,182,212,.3);color:#22D3EE">4</div>
      🔧 How LLMs Work
    </button>
    <button class="nav-item" onclick="goTo(5)" id="nav-5">
      <div class="nav-num" style="background:rgba(236,72,153,.2);border-color:rgba(236,72,153,.3);color:#F472B6">5</div>
      🤖 AI Agents
    </button>
