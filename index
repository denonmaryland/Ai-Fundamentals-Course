<script>
const TOTAL = 7;
let visited = new Set([0]);

function goTo(idx, pushState) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + idx).classList.add('active');
  document.getElementById('nav-' + idx).classList.add('active');
  if (idx > 0) visited.add(idx);
  updateProgress();
  window.scrollTo(0,0);
  if (pushState !== false) {
    history.pushState({page: idx}, '', '#' + idx);
  }
  closeMobileMenu();
}

function updateProgress() {
  const count = Math.max(0, visited.size - 1); // exclude home
  const pct = Math.round((count / TOTAL) * 100);
  document.getElementById('prog-fill').style.width = pct + '%';
  document.getElementById('prog-text').textContent = count + ' of ' + TOTAL;
}

function toggle(el) {
  el.classList.toggle('done');
  if (el.classList.contains('done')) {
    el.querySelector('.check').textContent = '✓';
  } else {
    el.querySelector('.check').textContent = '';
  }
}

// back to top
const main = document.querySelector('.main');
window.addEventListener('scroll', () => {
  document.getElementById('btt').classList.toggle('show', window.scrollY > 400);
});
function scrollToTop() { window.scrollTo({top:0, behavior:'smooth'}); }

// browser back/forward
window.addEventListener('popstate', e => {
  const idx = e.state?.page ?? 0;
  goTo(idx, false);
});

// load correct page from URL hash on initial load
(function() {
  const hash = window.location.hash.replace('#', '');
  const idx = parseInt(hash, 10);
  if (!isNaN(idx) && idx >= 0 && idx <= TOTAL) {
    goTo(idx, false);
  } else {
    history.replaceState({page: 0}, '', '#0');
  }
})();

// mobile menu
function openMobileMenu() {
  document.querySelector('.sidebar').classList.add('open');
  document.getElementById('mobile-overlay').classList.add('open');
}
function closeMobileMenu() {
  document.querySelector('.sidebar').classList.remove('open');
  document.getElementById('mobile-overlay').classList.remove('open');
}
</script>
